# ════════════════════════════════════════════════
#   FIB Platform — Environment Variables
# ════════════════════════════════════════════════

# ── JWT (REQUIRED) ───────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=fib-hq-cambia-esta-clave-por-algo-largo-y-aleatorio
# Optional alternative (Base64-encoded):
JWT_SECRET_B64=

# ── Supabase (REQUIRED for persistent data) ──────
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# OR use service role key (bypasses RLS — keep secret, server-only):
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optional alternative (Base64-encoded):
SUPABASE_SERVICE_ROLE_KEY_B64=

# NOTE: Without Supabase vars, the app runs fully in-memory
# (data resets on every cold start / Netlify function restart)

# ── Google Sheets (for /personal roster) ─────────
SPREADSHEET_ID=
GOOGLE_CREDENTIALS=

# ── Discord Webhooks (optional, for audit logs) ──
DISCORD_WEBHOOK_EXTRAS=
DISCORD_WEBHOOK_KEYS=
DISCORD_WEBHOOK_LOGINS=
DISCORD_WEBHOOK_IMPORTANTE=
# Optional alternative alias and Base64 options:
DISCORD_WEBHOOK_IMPORTANT=
DISCORD_WEBHOOK_IMPORTANTE_B64=
